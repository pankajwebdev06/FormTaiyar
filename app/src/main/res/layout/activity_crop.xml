<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_blue"
        app:title="Photo Taiyar Karein"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue_light"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTemplateName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAN Card Photo"
                android:textColor="@color/primary_blue_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTemplateDimension"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="35x25mm - Max 300KB"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            style="?android:attr/progressBarStyleSmall" />

    </LinearLayout>

    <!-- CROP PANEL -->
    <LinearLayout
        android:id="@+id/cropPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.formtaiyar.app.CropView
            android:id="@+id/cropImageView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface_card"
            android:padding="16dp">

            <!-- Custom size inputs -->
            <LinearLayout
                android:id="@+id/customSizePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etCustomWidth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Width (px)"
                    android:inputType="number"
                    android:text="400"
                    android:textSize="14sp"
                    android:padding="10dp"
                    android:background="@android:drawable/edit_text" />

                <EditText
                    android:id="@+id/etCustomHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Height (px)"
                    android:inputType="number"
                    android:text="400"
                    android:textSize="14sp"
                    android:padding="10dp"
                    android:background="@android:drawable/edit_text" />

            </LinearLayout>

            <!-- Quality slider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_compress"
                    android:tint="@color/primary_blue"
                    android:layout_marginEnd="8dp" />

                <SeekBar
                    android:id="@+id/seekbarQuality"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="85"
                    android:progressTint="@color/primary_blue"
                    android:thumbTint="@color/primary_blue" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvQualityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Quality: High (85%)"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Watermark toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/watermark_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchWatermark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCrop"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_crop"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- PREVIEW PANEL -->
    <LinearLayout
        android:id="@+id/previewPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/preview_label"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:maxWidth="280dp"
                    android:maxHeight="360dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tvSizeInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Size: --KB"
                    android:textColor="@color/primary_blue_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDimensionInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="-- x -- px"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface_card"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCropAgain"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:text="@string/btn_crop_again"
                android:textSize="14sp"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_save"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_save"
                    app:iconGravity="textStart"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_share"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_share"
                    app:iconGravity="textStart"
                    app:cornerRadius="10dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
