<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FormTaiyar" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/primary_blue_medium</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_blue_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Button style -->
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
    </style>

    <style name="Theme.FormTaiyar.Splash" parent="Theme.FormTaiyar">
        <item name="android:windowBackground">@color/primary_blue</item>
    </style>

</resources>
